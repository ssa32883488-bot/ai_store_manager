/* 首页样式：底层浅灰，减轻纯白刺眼感 */
page {
  background-color: #eceef1;
}

.container {
  padding: 0 48rpx;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
  min-height: 100vh;
}

/* 顶部用户信息栏 */
.user-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 0;
  margin-top: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 28rpx;
  min-width: 0;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  border: 4rpx solid #2dd4bf;
  flex-shrink: 0;
}

.user-text {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
  min-width: 0;
}

.nickname {
  font-size: 36rpx;
  color: #191c1e;
  font-weight: 700;
  line-height: 1.25;
}

.credit-text {
  font-size: 26rpx;
  color: #5a6b62;
  line-height: 1.35;
}

/* 胶囊切换 */
.mode-toggle {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: #e7e8ea;
  border-radius: 9999rpx;
  padding: 8rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.toggle-item {
  padding: 12rpx 32rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #6c7a71;
  border-radius: 9999rpx;
  transition: all 0.3s ease;
}

.toggle-item.active {
  background: #10b981;
  color: #ffffff;
  font-weight: 700;
}

/* 主内容区：占满横向，便于子元素与轮播同宽对齐 */
.main-content {
  width: 100%;
  box-sizing: border-box;
  padding-top: 32rpx;
  height: calc(100vh - 200rpx);
}

/* 横幅区域（轮播） */
.banner-section {
  position: relative;
  width: 100%;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 48rpx;
  height: 340rpx;
}

.banner-swiper {
  width: 100%;
  height: 340rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 核心操作区：与轮播同宽；van-button 需配合 block 属性才占满一行 */
.action-section {
  width: 100%;
  box-sizing: border-box;
  padding: 32rpx 0;
  margin-bottom: 32rpx;
}

/* Vant 按钮：icon + 文案由组件内联排布（van-button 本身即 align-items:center），勿再包一层自定义 flex */
van-button.start-btn {
  width: 100% !important;
  max-width: 100% !important;
  box-sizing: border-box !important;
  min-height: 400rpx !important;
  height: auto !important;
  padding: 48rpx 24rpx !important;
  border-radius: 9999rpx !important;
  box-shadow: 0 12rpx 40rpx rgba(13, 148, 136, 0.28) !important;
  border: none !important;
  font-size: 160rpx !important;
  line-height: 1.12 !important;
}

van-button.start-btn .van-button__text {
  color: #ffffff !important;
  font-size: 160rpx !important;
  font-weight: 800 !important;
  letter-spacing: 0 !important;
  line-height: 1.12 !important;
  /* 极大字号下单行可能超出屏宽，允许自动换行以免裁切 */
  white-space: normal !important;
  text-align: center !important;
  word-break: keep-all !important;
}

van-button.start-btn .van-button__icon {
  color: #ffffff !important;
  font-size: 180rpx !important;
  line-height: 1 !important;
  margin-right: 24rpx !important;
  vertical-align: middle !important;
  flex-shrink: 0 !important;
}

/* 灵感橱头 */
.inspiration-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 16rpx;
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #191c1e;
}

.view-more {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #006c49;
  font-weight: 500;
}

.arrow {
  font-size: 32rpx;
  font-weight: 700;
}

/* 瀑布流网格 */
.waterfall-grid {
  display: flex;
  gap: 32rpx;
  padding-bottom: 48rpx;
}

.grid-left, .grid-right {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

/* 卡片偏移效果 */
.card-offset {
  margin-top: 48rpx;
}

/* 灵感卡片 */
.inspiration-card {
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(25, 28, 30, 0.04);
  transition: transform 0.2s ease;
}

.inspiration-card:active {
  transform: scale(0.98);
}

.card-image-wrapper {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.card-image {
  width: 100%;
  height: 100%;
}

.card-tag {
  position: absolute;
  top: 24rpx;
  left: 24rpx;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10rpx);
  -webkit-backdrop-filter: blur(10rpx);
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #191c1e;
}

.card-action {
  padding: 24rpx;
}

.action-btn {
  width: 100%;
  background: rgba(0, 108, 73, 0.05);
  padding: 24rpx 0;
  border-radius: 9999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  transition: background 0.2s ease;
}

.action-btn:active {
  background: rgba(0, 108, 73, 0.1);
}

.star-icon {
  font-size: 24rpx;
}

.action-text {
  font-size: 28rpx;
  font-weight: 700;
  color: #006c49;
}
