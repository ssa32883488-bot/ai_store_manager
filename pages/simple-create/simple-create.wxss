/* 极简制作页样式 */
page {
  background-color: #f8f9fb;
  min-height: 100vh;
}

.simple-create-container {
  min-height: 100vh;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

/* 顶部导航栏 */
.nav-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  background: #f8f9fb;
  z-index: 100;
}

.back-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #191c1e;
}

.step-indicator {
  font-size: 28rpx;
  font-weight: 700;
  color: #10b981;
}

/* 步骤进度条 */
.progress-bar {
  position: fixed;
  top: 96rpx;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #e7e8ea;
  z-index: 99;
}

.progress-fill {
  height: 100%;
  background: #10b981;
  transition: width 0.5s cubic-bezier(0.4, 0, 0.2, 1);
}

/* 主内容区 */
.main-content {
  padding-top: 140rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
  height: 100vh;
  box-sizing: border-box;
}

/* 步骤区块 */
.step-section {
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
}

.step-section.hidden {
  display: none;
}

.step-section.active {
  display: block;
  animation: fadeIn 0.4s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.step-header {
  margin-bottom: 48rpx;
}

.step-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #191c1e;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.step-subtitle {
  font-size: 28rpx;
  color: #6c7a71;
}

/* 第一步：发布渠道大按钮 */
.publish-channel-list {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.publish-channel-btn {
  position: relative;
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 36rpx 32rpx;
  background: #ffffff;
  border-radius: 28rpx;
  border: 4rpx solid transparent;
  box-shadow: 0 8rpx 28rpx rgba(25, 28, 30, 0.06);
}

.publish-channel-btn.selected {
  border-color: #10b981;
  box-shadow: 0 8rpx 28rpx rgba(16, 185, 129, 0.18);
}

.publish-channel-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
  overflow: hidden;
  display: block;
  background: #f2f4f6;
}

.publish-channel-icon-img {
  width: 100%;
  height: 100%;
  display: block;
  border-radius: 20rpx;
}

.publish-channel-name {
  flex: 1;
  margin-left: 32rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #191c1e;
}

.publish-channel-check {
  flex-shrink: 0;
  margin-left: 16rpx;
}

/* 表单区 */
.form-section {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
}

.input-group {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.input-label {
  font-size: 30rpx;
  font-weight: 700;
  color: #191c1e;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.product-input {
  flex: 1;
  height: 100rpx;
  background: #f2f4f6;
  border-radius: 24rpx;
  padding: 0 140rpx 0 32rpx;
  font-size: 32rpx;
  color: #191c1e;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.product-input:focus {
  border-color: #006c49;
  background: #ffffff;
}

.placeholder {
  color: rgba(60, 74, 66, 0.5);
}

.supplement-textarea {
  width: 100%;
  min-height: 200rpx;
  box-sizing: border-box;
  padding: 28rpx 32rpx;
  background: #f2f4f6;
  border-radius: 24rpx;
  font-size: 30rpx;
  color: #191c1e;
  line-height: 1.55;
  border: 2rpx solid transparent;
}

.supplement-textarea:focus {
  border-color: #006c49;
  background: #ffffff;
}

.mic-btn {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 72rpx;
  height: 72rpx;
  background: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 108, 73, 0.2);
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-tag {
  padding: 20rpx 40rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #e7e8ea;
  color: #191c1e;
  transition: all 0.3s ease;
}

.category-tag.selected {
  background: #10b981;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.25);
}

/* 上传区域 */
.upload-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.upload-area {
  width: 100%;
  height: 360rpx;
  border: 4rpx dashed #bbcabf;
  border-radius: 24rpx;
  background: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.upload-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.upload-icon-wrapper {
  width: 120rpx;
  height: 120rpx;
  background: #f2f4f6;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.upload-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #6c7a71;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.delete-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 0, 0, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 提示卡片 */
.tip-card {
  display: flex;
  gap: 24rpx;
  background: #f2f4f6;
  padding: 32rpx;
  border-radius: 24rpx;
  border-left: 8rpx solid #006c49;
  align-items: flex-start;
}

.tip-icon-wrapper {
  width: 64rpx;
  height: 64rpx;
  background: rgba(0, 108, 73, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tip-text {
  flex: 1;
  font-size: 28rpx;
  color: #6c7a71;
  line-height: 1.6;
  padding-top: 8rpx;
}

/* 第三步：参考风格（品类 Tab + 风格网格） */
.ref-style-section {
  margin-bottom: 8rpx;
}

.ref-style-hint {
  display: block;
  font-size: 24rpx;
  color: #6c7a71;
  line-height: 1.55;
  margin-bottom: 24rpx;
}

.ref-mode-toggle {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ref-mode-btn {
  height: 76rpx;
  border-radius: 9999rpx;
  background: #e7e8ea;
  color: #191c1e;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ref-mode-btn.selected {
  background: #10b981;
  color: #ffffff;
}

.ref-category-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 28rpx;
}

.ref-category-inner {
  display: inline-flex;
  flex-direction: row;
  gap: 16rpx;
  padding-bottom: 4rpx;
}

.ref-category-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 36rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #e7e8ea;
  color: #191c1e;
  flex-shrink: 0;
  transition: all 0.25s ease;
}

.ref-category-pill.selected {
  background: #006c49;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(0, 108, 73, 0.28);
}

.ref-style-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.ref-style-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  border: 4rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(25, 28, 30, 0.04);
  position: relative;
  transition: all 0.3s ease;
}

.ref-style-card.selected {
  border-color: #10b981;
  box-shadow: 0 8rpx 24rpx rgba(16, 185, 129, 0.2);
}

.ref-style-image {
  width: 100%;
  height: 240rpx;
}

.ref-style-label {
  padding: 20rpx 16rpx 24rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
  color: #191c1e;
  background: #ffffff;
  line-height: 1.35;
}

.selected-check {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 40rpx;
  height: 40rpx;
  background: #10b981;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ref-style-grid.preset-muted .ref-style-card {
  opacity: 0.5;
}

.upload-ref-box {
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
  background: #e7e8ea;
  border: 2rpx dashed #bbcabf;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 18rpx;
}

.upload-ref-plus {
  font-size: 88rpx;
  line-height: 1;
  color: #6c7a71;
}

.upload-ref-tip {
  font-size: 28rpx;
  color: #6c7a71;
  font-weight: 600;
}

.composition-hint {
  margin-top: 24rpx;
  margin-bottom: 0;
}

.composition-hint-text {
  font-size: 24rpx;
  color: #6c7a71;
  line-height: 1.5;
}

.ref-replace-tip {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #6c7a71;
  text-align: center;
}

.ref-preview-area {
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
  background: #e7e8ea;
}

.ref-preview-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 选项区块 */
.option-section {
  margin-bottom: 40rpx;
}

.section-title-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #191c1e;
}

.platform-list, .tone-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.platform-tag, .tone-tag {
  padding: 20rpx 40rpx;
  border-radius: 9999rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: #e7e8ea;
  color: #191c1e;
  transition: all 0.3s ease;
}

.platform-tag.selected, .tone-tag.selected {
  background: #10b981;
  color: #ffffff;
  box-shadow: 0 4rpx 16rpx rgba(16, 185, 129, 0.25);
}

/* 准备就绪卡片 */
.ready-card {
  padding: 32rpx;
  background: rgba(0, 108, 73, 0.05);
  border-radius: 24rpx;
  border: 2rpx solid rgba(0, 108, 73, 0.1);
  margin-top: 40rpx;
}

.ready-text {
  display: block;
  text-align: center;
  font-size: 30rpx;
  font-weight: 700;
  color: #006c49;
}

/* 底部占位 */
.bottom-spacer {
  height: 120rpx;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 48rpx 48rpx 0 0;
  padding: 32rpx 48rpx;
  box-shadow: 0 -8rpx 32rpx rgba(25, 28, 30, 0.06);
  z-index: 100;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.back-step-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 16rpx;
}

.back-step-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #6c7a71;
}

van-button.next-btn,
van-button.generate-btn {
  height: 100rpx !important;
  box-shadow: 0 8rpx 32rpx rgba(0, 108, 73, 0.25) !important;
}

van-button.next-btn .van-button__text,
van-button.generate-btn .van-button__text {
  font-size: 32rpx !important;
  font-weight: 700 !important;
  display: flex !important;
  align-items: center !important;
  gap: 12rpx !important;
}

.next-text,
.generate-text {
  color: #ffffff;
}

/* 安全区适配 */
.safe-area-bottom {
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
}

/* 第五步：Lottie 占位 + 内联结果 */
.lottie-slot {
  width: 100%;
  min-height: 360rpx;
  margin: 32rpx 0 24rpx;
  border-radius: 24rpx;
  background: #eef1f4;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.lottie-placeholder-inner {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, rgba(16, 185, 129, 0.25), rgba(0, 108, 73, 0.15));
}

.generating-hint {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #6c7a71;
  line-height: 1.6;
  padding: 0 16rpx 24rpx;
}

.step5-footer-hint {
  text-align: center;
  font-size: 28rpx;
  color: #6c7a71;
  padding: 8rpx 0 0;
}

.inline-result-tag {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 700;
  color: #006c49;
  background: rgba(0, 108, 73, 0.1);
  padding: 12rpx 24rpx;
  border-radius: 9999rpx;
  margin-bottom: 24rpx;
}

.inline-result-image-card {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(25, 28, 30, 0.06);
  margin-bottom: 20rpx;
}

.inline-result-image {
  width: 100%;
  display: block;
  vertical-align: top;
}

.inline-image-actions {
  margin-bottom: 40rpx;
}

.inline-result-section {
  margin-bottom: 40rpx;
}

.inline-section-head {
  margin-bottom: 20rpx;
}

.inline-section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #191c1e;
  margin-bottom: 8rpx;
}

.inline-section-hint {
  font-size: 24rpx;
  color: #6c7a71;
}

.inline-option-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.inline-option-item {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  border: 3rpx solid transparent;
  box-shadow: 0 4rpx 16rpx rgba(25, 28, 30, 0.04);
}

.inline-option-item.selected {
  border-color: #10b981;
  background: rgba(16, 185, 129, 0.06);
}

.inline-option-text {
  font-size: 28rpx;
  color: #191c1e;
  line-height: 1.55;
}

.inline-option-item.copy-item .inline-option-text {
  line-height: 1.65;
}

.inline-copy-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.inline-copy-btn {
  flex: 1;
  min-width: 200rpx;
}

.image-download-btn {
  min-width: 100% !important;
}
