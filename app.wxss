/* 全局样式文件 */
page {
  --color-primary: #006c49;
  --color-primary-container: #10b981;
  --color-on-primary: #ffffff;
  --color-on-primary-container: #00422b;
  --color-secondary: #376850;
  --color-secondary-container: #b7ebce;
  --color-on-secondary: #ffffff;
  --color-on-secondary-container: #3c6c54;
  --color-tertiary: #a43a3a;
  --color-tertiary-container: #fc7c78;
  --color-surface: #f8f9fb;
  --color-surface-dim: #d9dadc;
  --color-surface-bright: #f8f9fb;
  --color-surface-container: #edeef0;
  --color-surface-container-low: #f2f4f6;
  --color-surface-container-lowest: #ffffff;
  --color-surface-container-high: #e7e8ea;
  --color-surface-container-highest: #e1e2e4;
  --color-on-surface: #191c1e;
  --color-on-surface-variant: #3c4a42;
  --color-outline: #6c7a71;
  --color-outline-variant: #bbcabf;
  --color-background: #f8f9fb;
  --color-error: #ba1a1a;
  --color-error-container: #ffdad6;
  --color-on-error: #ffffff;
  --color-inverse-surface: #2e3132;
  --color-inverse-on-surface: #f0f1f3;
  --color-inverse-primary: #4edea3;
  
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;
  background-color: var(--color-surface);
  color: var(--color-on-surface);
  -webkit-tap-highlight-color: transparent;
}

/* 字体 */
.font-headline {
  font-weight: 600;
  letter-spacing: -0.02em;
}

.font-body {
  font-weight: 400;
  letter-spacing: 0;
}

/* 安全区域适配 */
.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 卡片阴影 */
.card-shadow {
  box-shadow: 0 8px 20px rgba(25, 28, 30, 0.04);
}

.shadow-lg-custom {
  box-shadow: 0 12px 32px rgba(25, 28, 30, 0.06);
}

/* 玻璃效果 */
.glass-effect {
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

/* 渐变背景 */
.gradient-primary {
  background: linear-gradient(135deg, #006c49 0%, #10b981 100%);
}

/* 隐藏滚动条 */
.hide-scrollbar::-webkit-scrollbar {
  display: none;
}

.hide-scrollbar {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

/* 按钮动画 */
.btn-active:active {
  transform: scale(0.96);
  opacity: 0.9;
}

/* 通用容器 */
.container {
  padding: 0 48rpx;
}

/* 弹性布局 */
.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* 文本省略 */
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
